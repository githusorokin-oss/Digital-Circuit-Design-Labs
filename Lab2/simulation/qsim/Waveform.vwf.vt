// x1
initial
begin
	x1 = 1'b1;
	x1 = #5000 1'b0;
	x1 = #5000 1'b1;
	x1 = #15000 1'b0;
	x1 = #5000 1'b1;
	x1 = #5000 1'b0;
	x1 = #5000 1'b1;
	x1 = #5000 1'b0;
	x1 = #5000 1'b1;
	x1 = #10000 1'b0;
	x1 = #20000 1'b1;
	x1 = #5000 1'b0;
end 

// x2
initial
